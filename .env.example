# transcript.lol — get from https://transcript.lol → API Docs
# Paste your real key into a separate .env (gitignored), never commit.
TRANSCRIPT_LOL_API_KEY=***

# Skool session cookies — export via browser extension while logged in
# Chrome: "Get cookies.txt LOCALLY"  |  Firefox: "cookies.txt"
SKOOL_COOKIES_PATH=./cookies/skool.txt

# Which Skool classroom to crawl
SKOOL_CLASSROOM_URL=https://www.skool.com/coliving-freedom-unlocked-5532/classroom

# Where captured transcripts and the manifest live.
VAULT_DIR=
VAULT_OUTPUT_DIR=

# Optional Notte fallback
NOTTE_API_KEY=

# transcript.lol tier hint, used only to warn before running
# Allowed: free | unlimited | team
TRANSCRIPT_LOL_TIER=free

# Agent-core go-live controls (src/main.py)
# Default-safe: anything except "live" keeps OpenPhone sends simulated.
ENGINE_MODE=simulation
ENGINE_WEBHOOK_TOKEN=replace-with-random-shared-secret
ENGINE_AUDIT_LOG=logs/engine_dispatch.jsonl

# OpenPhone/Quo outbound. Required only when ENGINE_MODE=live.
OPENPHONE_API_KEY=
OPENPHONE_FROM_NUMBER=+15555550100

# Optional n8n callback.
N8N_WEBHOOK_URL=
N8N_API_KEY=

# Optional Gemini personalization. Leave unset for deterministic-only rollout.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
