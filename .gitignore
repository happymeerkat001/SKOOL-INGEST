# secrets and session material
.env
.env.*
!.env.example
cookies/
*.txt
!cookies/.gitkeep
manifest/skool_cookies_*.txt

# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/

# editor / OS
.DS_Store
.idea/
.vscode/

# run outputs
logs/
captures/
!tests/fixtures/**/captures/
!tests/fixtures/**/captures/**
!tests/fixtures/**/*.txt
tests/fixtures/**/.DS_Store
manifest/*.json
!manifest/.gitkeep
# Skool video index regenerates from scripts/build_video_index.py + crawls;
# never commit the rolling snapshots — rebuild them locally instead.
manifest/skool_videos.before-*.csv
manifest/skool_videos.merged.csv
manifest/video_index.html
manifest/local_ingest/
manifest/fb_leads/
.claude/
